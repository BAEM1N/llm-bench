# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Results (large CSV files) — local runs ignored, remote + consolidated tracked
results/*.csv
results/*.log
!results/remote/
!results/consolidated/

# Charts
charts/

# Logs (run outputs) — keep directory, ignore contents
logs/*
!logs/.gitkeep

# Temp
*.log
nohup.out

# Local tooling state
.omx/
.claude/
